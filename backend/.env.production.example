# Production environment variables — NDIS CRM Backend
# Copy this file to .env.production and fill in all values before deploying.
# NEVER commit .env.production to version control.

# ---------------------------------------------------------------------------
# Database
# ---------------------------------------------------------------------------
DATABASE_URL=postgresql+asyncpg://ndis_crm_app:CHANGE_ME@/ndis_crm?host=/cloudsql/PROJECT:australia-southeast1:ndis-crm-postgres

# ---------------------------------------------------------------------------
# Redis / Celery broker
# ---------------------------------------------------------------------------
REDIS_URL=redis://10.x.x.x:6379/0

# ---------------------------------------------------------------------------
# Auth0
# ---------------------------------------------------------------------------
AUTH0_DOMAIN=your-org.au.auth0.com
AUTH0_AUDIENCE=https://ndis-crm-api
AUTH0_CLIENT_ID=
AUTH0_CLIENT_SECRET=

# ---------------------------------------------------------------------------
# Google Cloud Storage
# ---------------------------------------------------------------------------
GCS_BUCKET_NAME=ndis-crm-documents-prod
GCS_PROJECT_ID=your-gcp-project-id
GOOGLE_APPLICATION_CREDENTIALS=/secrets/gcs-key.json

# ---------------------------------------------------------------------------
# Google Document AI (invoice OCR)
# ---------------------------------------------------------------------------
DOCUMENT_AI_PROJECT_ID=your-gcp-project-id
DOCUMENT_AI_LOCATION=us
DOCUMENT_AI_PROCESSOR_ID=

# ---------------------------------------------------------------------------
# Microsoft Graph API (Outlook integration)
# ---------------------------------------------------------------------------
GRAPH_CLIENT_ID=
GRAPH_CLIENT_SECRET=
GRAPH_TENANT_ID=
GRAPH_SHARED_MAILBOX=invoices@your-org.com.au
GRAPH_FROM_MAILBOX=notifications@your-org.com.au
GRAPH_PROCESSED_FOLDER_ID=
GRAPH_CORRESPONDENCE_FOLDER_ID=

# ---------------------------------------------------------------------------
# Xero integration
# ---------------------------------------------------------------------------
XERO_CLIENT_ID=
XERO_CLIENT_SECRET=
XERO_REDIRECT_URI=https://api.ndis-crm.your-org.com.au/xero/callback
XERO_WEBHOOK_KEY=

# ---------------------------------------------------------------------------
# Web Push (VAPID)
# ---------------------------------------------------------------------------
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
