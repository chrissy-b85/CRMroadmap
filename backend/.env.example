DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/ndis_crm
REDIS_URL=redis://localhost:6379/0
AUTH0_DOMAIN=your-tenant.auth0.com
AUTH0_AUDIENCE=https://api.ndis-crm.com
AUTH0_CLIENT_SECRET=
GCP_PROJECT_ID=your-gcp-project-id
GCP_SERVICE_ACCOUNT_KEY=/path/to/service-account-key.json

# Microsoft Graph API
GRAPH_TENANT_ID=
GRAPH_CLIENT_ID=
GRAPH_CLIENT_SECRET=
GRAPH_SHARED_MAILBOX=invoices@your-org.com.au
GRAPH_PROCESSED_FOLDER_ID=
GRAPH_CORRESPONDENCE_FOLDER_ID=
GRAPH_FROM_MAILBOX=notifications@your-org.com.au

# Google Document AI
DOCUMENT_AI_PROJECT_ID=
DOCUMENT_AI_LOCATION=us
DOCUMENT_AI_PROCESSOR_ID=

# GCS
GCS_BUCKET_INVOICES=ndis-crm-invoices

# Celery / Redis
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# Xero Integration
XERO_CLIENT_ID=
XERO_CLIENT_SECRET=
XERO_REDIRECT_URI=http://localhost:8000/xero/callback
XERO_WEBHOOK_KEY=

# DigitalOcean (set STORAGE_BACKEND=spaces to use Spaces instead of GCS)
STORAGE_BACKEND=gcs
DO_SPACES_KEY=
DO_SPACES_SECRET=
DO_SPACES_REGION=syd1
DO_SPACES_BUCKET=ndis-crm-files
DO_SPACES_ENDPOINT=https://syd1.digitaloceanspaces.com
DIGITALOCEAN_ACCESS_TOKEN=
