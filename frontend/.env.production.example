# Production environment variables — NDIS CRM Frontend
# Copy this file to .env.production.local and fill in all values before deploying.
# NEVER commit .env.production.local to version control.

# ---------------------------------------------------------------------------
# API
# ---------------------------------------------------------------------------
NEXT_PUBLIC_API_URL=https://api.ndis-crm.your-org.com.au

# ---------------------------------------------------------------------------
# Auth0 (next-auth0 SDK)
# ---------------------------------------------------------------------------
AUTH0_SECRET=
AUTH0_BASE_URL=https://ndis-crm.your-org.com.au
AUTH0_ISSUER_BASE_URL=https://your-org.au.auth0.com
AUTH0_CLIENT_ID=
AUTH0_CLIENT_SECRET=
NEXT_PUBLIC_AUTH0_AUDIENCE=https://ndis-crm-api

# ---------------------------------------------------------------------------
# Web Push (VAPID)
# ---------------------------------------------------------------------------
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
